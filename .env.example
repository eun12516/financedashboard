# --- Database (필수) ---
# Supabase 사용 시: 대시보드 → Project Settings → Database → Connection string 참고
#
# DATABASE_URL  = Transaction pooler (보통 포트 6543, 서버/Prisma 런타임)
# DIRECT_URL    = Direct 또는 Session (보통 포트 5432, prisma db push / migrate)
#
# 로컬 Postgres만 쓸 때는 두 값을 동일하게 두면 됩니다.

DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- Optional: Supabase 클라이언트 (브라우저 Auth·Realtime 등) ---
# Prisma와 별개. 없어도 서버는 DATABASE_URL로 동작합니다.
# Project Settings → API 에서 Project URL / Publishable key 복사
# NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# --- Optional: OpenAI (서버 전용 — 브라우저로 노출되지 않음) ---
# 키가 없으면 인사이트는 규칙 기반으로만 동작합니다. 분류·인사이트 모델은 선택 사항입니다.
#
# OPENAI_API_KEY="sk-..."
# OPENAI_INSIGHTS_MODEL="gpt-5-mini"
# OPENAI_CLASSIFICATION_MODEL="gpt-5-mini"
