// Aligns with db/schema.sql — personal finance ingestion + dedupe

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Supabase: Transaction pooler (port 6543) 권장. 마이그레이션은 directUrl 사용.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// App user (1:1 with Supabase Auth `auth.users.id` when using email login).
model User {
  id        String   @id @db.Uuid
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  accounts                Account[]
  uploads                 Upload[]
  transactions            Transaction[]
  workbookSheet1Snapshots WorkbookSheet1Snapshot[]

  @@map("users")
}

model TransferClassification {
  id          Int           @id @default(autoincrement()) @db.SmallInt
  code        String        @unique
  label       String
  sortOrder   Int           @default(0) @map("sort_order") @db.SmallInt
  transactions Transaction[]

  @@map("transfer_classifications")
}

model Account {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  name         String
  currency     String        @default("KRW") @db.Char(3)
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  sheet1Snapshots WorkbookSheet1Snapshot[]

  @@unique([userId, name], map: "uq_accounts_user_name")
  @@index([userId], map: "ix_accounts_user_id")
  @@map("accounts")
}

model Upload {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String      @map("user_id") @db.Uuid
  originalFilename String    @map("original_filename")
  fileSha256       Bytes?    @map("file_sha256")
  status           String    @default("pending")
  rowsInserted     Int       @default(0) @map("rows_inserted")
  rowsDuplicate    Int       @default(0) @map("rows_duplicate")
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt      DateTime? @map("completed_at") @db.Timestamptz(6)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  sheet1Snapshot   WorkbookSheet1Snapshot?

  @@index([userId], map: "ix_uploads_user_id")
  @@map("uploads")
}

/// Parsed Sheet1 (요약 리포트) from 2-sheet household Excel — not used for transaction rows.
model WorkbookSheet1Snapshot {
  id        String @id @default(uuid()) @db.Uuid
  userId    String @map("user_id") @db.Uuid
  accountId String @map("account_id") @db.Uuid
  uploadId  String @unique @map("upload_id") @db.Uuid

  /// 고객정보: { name, gender, age, creditScore, email }
  customer Json? @db.JsonB
  /// 현금흐름현황: { monthKeys, rows }
  cashflow Json? @db.JsonB
  /// 재무/투자/대출/보험 등 나머지 블록
  extra    Json? @db.JsonB

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  upload  Upload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([accountId], map: "ix_sheet1_account_id")
  @@index([userId], map: "ix_sheet1_user_id")
  @@map("workbook_sheet1_snapshots")
}

model Transaction {
  id                         String   @id @default(uuid()) @db.Uuid
  userId                     String   @map("user_id") @db.Uuid
  accountId                  String   @map("account_id") @db.Uuid
  firstSeenUploadId          String?  @map("first_seen_upload_id") @db.Uuid
  occurredOn                 DateTime @map("occurred_on") @db.Date
  amount                     Decimal  @db.Decimal(19, 4)
  merchant                   String   @default("")
  merchantNormalized         String   @default("") @map("merchant_normalized")
  dedupeHash                 Bytes    @map("dedupe_hash")
  description                String?
  categoryRaw                String?  @map("category_raw")
  /// Sheet2 column `결제수단` when present — used for 사업자/법인카드 → 사업비 분류
  paymentMethod              String?  @map("payment_method")
  isTransfer                 Boolean  @default(false) @map("is_transfer")
  transferClassificationId   Int?     @map("transfer_classification_id") @db.SmallInt
  /// User changed 분류 in UI — ingest will not overwrite on duplicate hash skip anyway
  classificationManual       Boolean  @default(false) @map("classification_manual")
  createdAt                  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account        Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  upload         Upload?                 @relation(fields: [firstSeenUploadId], references: [id], onDelete: SetNull)
  classification TransferClassification? @relation(fields: [transferClassificationId], references: [id], onDelete: SetNull)

  @@unique([accountId, dedupeHash], map: "uq_transactions_account_dedupe")
  @@index([userId], map: "ix_transactions_user_id")
  @@map("transactions")
}
